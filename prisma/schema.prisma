// Prisma schema для соцсети mesto
// Документация: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  PENDING // заявка отправлена, ждёт ответа
  ACCEPTED // дружба подтверждена
  DECLINED // заявка отклонена
  BLOCKED // пользователь заблокирован
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String? // null у пользователей, вошедших через OAuth
  username     String   @unique
  displayName  String
  avatarUrl    String?
  coverUrl     String? // обложка профиля
  bio          String?
  status       String? // короткий статус под именем
  location     String? // город
  website      String? // ссылка на сайт/соцсеть
  isPrivate    Boolean  @default(false) // закрытый профиль
  lastSeenAt   DateTime? // последняя активность — для онлайн-статуса
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Дружба, где этот пользователь — инициатор заявки
  sentFriendRequests     Friendship[] @relation("FriendshipRequester")
  // Дружба, где этот пользователь — получатель заявки
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")

  posts    Post[]
  likes    Like[]
  comments Comment[]

  // Диалоги: участие в беседах (1-на-1 и групповых) + отправленные сообщения.
  convParticipations ConversationParticipant[]
  ownedConversations Conversation[]           @relation("ConvOwner")
  messages           Message[]
  messageReactions   MessageReaction[]

  // Истории (24ч) и их просмотры.
  stories    Story[]
  storyViews StoryView[]

  ownedGroups        Group[]           @relation("GroupOwner")
  memberships        GroupMembership[]
  notifications      Notification[]    @relation("NotifRecipient")
  actedNotifications Notification[]    @relation("NotifActor")

  @@index([displayName])
}

model Post {
  id        String    @id @default(cuid())
  authorId  String
  groupId   String? // если задан — пост опубликован от лица сообщества
  content   String
  imageUrl  String?
  editedAt  DateTime? // проставляется при редактировании
  createdAt DateTime  @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]

  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  emoji     String   @default("👍") // тип реакции
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Один пользователь — одна реакция на пост
  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  authorId  String
  parentId  String? // ответ на другой комментарий
  content   String
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  // Одна пара пользователей — одна запись дружбы
  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([requesterId])
}

// Беседа: и личная (1-на-1), и групповая. Участники — в ConversationParticipant.
// Для личной беседы isGroup=false и ровно два участника; уникальность пары
// обеспечивается на уровне приложения (getOrCreateConversation).
model Conversation {
  id            String   @id @default(cuid())
  isGroup       Boolean  @default(false)
  title         String? // название групповой беседы
  avatarUrl     String? // аватар групповой беседы
  ownerId       String? // создатель групповой беседы
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  owner        User?                     @relation("ConvOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

// Участник беседы. Здесь же — эфемерное состояние чтения и набора текста,
// одинаково работающее для личных и групповых бесед.
model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  role           GroupRole @default(MEMBER)
  lastReadAt     DateTime? // до какого момента участник прочитал беседу
  lastTypingAt   DateTime? // когда последний раз печатал (TTL ~5с для индикатора)
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  imageUrl       String? // прикреплённая картинка
  replyToId      String? // ответ-цитата на другое сообщение
  editedAt       DateTime? // проставляется при редактировании
  deletedAt      DateTime? // мягкое удаление → «сообщение удалено»
  createdAt      DateTime  @default(now())

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?          @relation("MsgReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MsgReply")
  reactions    MessageReaction[]

  @@index([conversationId, createdAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Один пользователь — одна реакция на сообщение.
  @@unique([messageId, userId])
  @@index([messageId])
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

model Group {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  avatarUrl   String?
  ownerId     String
  createdAt   DateTime @default(now())

  owner   User              @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMembership[]
  posts   Post[]

  @@index([name])
}

model GroupMembership {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPT
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  MENTION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String // получатель
  actorId   String // кто совершил действие
  type      NotificationType
  entityId  String? // id связанной сущности (пост и т.п.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// История: фото на 24 часа. Активна, пока expiresAt в будущем.
model Story {
  id        String   @id @default(cuid())
  authorId  String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 24ч

  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views  StoryView[]

  @@index([authorId, expiresAt])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  // Один зритель — один просмотр истории.
  @@unique([storyId, viewerId])
}
