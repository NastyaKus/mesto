# Подключение к PostgreSQL (Neon/Supabase или локальный).
# Пример Neon: postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Секрет для подписи сессий Auth.js. Сгенерировать: npx auth secret
AUTH_SECRET="replace-with-generated-secret"
