// Prisma schema для соцсети mesto
// Документация: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  PENDING // заявка отправлена, ждёт ответа
  ACCEPTED // дружба подтверждена
  DECLINED // заявка отклонена
  BLOCKED // пользователь заблокирован
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String   @unique
  displayName  String
  avatarUrl    String?
  coverUrl     String? // обложка профиля
  bio          String?
  status       String? // короткий статус под именем
  location     String? // город
  website      String? // ссылка на сайт/соцсеть
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Дружба, где этот пользователь — инициатор заявки
  sentFriendRequests     Friendship[] @relation("FriendshipRequester")
  // Дружба, где этот пользователь — получатель заявки
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")

  posts    Post[]
  likes    Like[]
  comments Comment[]

  // Диалоги: пользователь может быть участником «A» или «B» пары.
  conversationsA Conversation[] @relation("ConversationA")
  conversationsB Conversation[] @relation("ConversationB")
  messages       Message[]

  ownedGroups        Group[]           @relation("GroupOwner")
  memberships        GroupMembership[]
  notifications      Notification[]    @relation("NotifRecipient")
  actedNotifications Notification[]    @relation("NotifActor")

  @@index([displayName])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  groupId   String? // если задан — пост опубликован от лица сообщества
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]

  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Один пользователь — один лайк на пост
  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  // Одна пара пользователей — одна запись дружбы
  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([requesterId])
}

// Диалог 1-на-1. aId/bId всегда упорядочены (aId < bId),
// чтобы пара пользователей давала ровно один диалог.
model Conversation {
  id            String   @id @default(cuid())
  aId           String
  bId           String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  a        User      @relation("ConversationA", fields: [aId], references: [id], onDelete: Cascade)
  b        User      @relation("ConversationB", fields: [bId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([aId, bId])
  @@index([aId])
  @@index([bId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  imageUrl       String? // прикреплённая картинка
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

model Group {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  avatarUrl   String?
  ownerId     String
  createdAt   DateTime @default(now())

  owner   User              @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMembership[]
  posts   Post[]

  @@index([name])
}

model GroupMembership {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPT
  POST_LIKE
  POST_COMMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String // получатель
  actorId   String // кто совершил действие
  type      NotificationType
  entityId  String? // id связанной сущности (пост и т.п.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user  User @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}
